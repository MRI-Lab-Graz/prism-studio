            "de": "Ich fühlte mich traurig oder deprimiert"
        },
        "Reversed": false,
        "Levels": {
            "0": {
                "en": "not at all true (0 days)",
                "de": "gar nicht wahr (0 Tage)"
            },
            "1": {
                "en": "rarely true (1-2 days)",
                "de": "selten zutreffend (1-2 Tage)"
