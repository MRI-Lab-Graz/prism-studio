{
  "$schema": "https://signpath.io/schemas/SignPathConfig-v1.json",
  "ElementTypes": [
    {
      "Name": "PrismStudio",
      "Kind": "PortableExecutable"
    }
  ],
  "ArtifactConfigurations": [
    {
      "Id": "windows-executable",
      "Description": "PRISM Studio Windows Executable",
      "PathMatching": {
        "Include": [
          "dist/PrismStudio/PrismStudio.exe"
        ]
      },
      "ElementsConfiguration": {
        "Elements": [
          {
            "Type": "PrismStudio",
            "Path": "PrismStudio.exe",
            "DeepSign": true
          }
        ]
      }
    }
  ]
}
